---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout
  lang="en"
  title="Page Not Found | Stage 4th Society"
  description="The page you are looking for could not be found."
>
  <section class="wrap not-found">
    <div class="eyebrow">404</div>
    <h1 class="display">Page Not Found</h1>
    <p>This page is not available. Return to the homepage to keep exploring.</p>
    <div class="not-found-actions">
      <a class="btn" href="/en">Home <span class="arr">→</span></a>
      <a class="btn secondary" href="/zh">中文首页</a>
    </div>
  </section>
</BaseLayout>

<style>
  .not-found {
    min-height: 62vh;
    display: grid;
    align-content: center;
    gap: 24px;
    padding-top: 96px;
    padding-bottom: 96px;
  }

  .not-found p {
    color: var(--muted);
    max-width: 620px;
  }

  .not-found-actions {
    display: flex;
    flex-wrap: wrap;
    gap: 12px;
  }
</style>
