---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { copy, languages, siteContact, site, type Lang } from "../../data/site";

export function getStaticPaths() {
  return languages.map((lang) => ({ params: { lang } }));
}

const lang = Astro.params.lang as Lang;
const t = copy[lang];
const c = siteContact[lang];
---
<BaseLayout lang={lang} title={`${t.contactTitle} | ${site.brand[lang].primary}`} description={t.contactIntro}>
  <section class="head">
    <div class="wrap">
      <span class="eyebrow">Contact — 联系</span>
      <h1 class="display">{t.contactTitle}</h1>
      <p class="lead">{t.contactIntro}</p>
    </div>
  </section>

  <section class="cells-section">
    <div class="wrap">
      <div class="cells">
        {c.cells.map((cell) =>
          cell.href === "#" ? (
            <div class="cell">
              <span class="k">{cell.label}</span>
              <strong>{cell.value}</strong>
              <span class="meta">{cell.meta}</span>
            </div>
          ) : (
            <a class="cell" href={cell.href} target={cell.href.startsWith("http") ? "_blank" : undefined} rel="noreferrer">
              <span class="k">{cell.label}</span>
              <strong>{cell.value}</strong>
              <span class="meta">{cell.meta}</span>
            </a>
          )
        )}
      </div>
    </div>
  </section>

  <section class="qr-section">
    <div class="wrap qr-row">
      <div class="qr-card">
        <span class="k">小红书 / Xiaohongshu</span>
        <div class="qr"><img src={site.xhsQr} alt="Xiaohongshu QR code" /></div>
        <span class="meta">Stage 4th Society</span>
      </div>
      <div class="qr-card">
        <span class="k">微信 / WeChat</span>
        <div class="qr id-card"><strong>{site.wechatId}</strong><span>WeChat ID</span></div>
        <span class="meta">{site.wechatId}</span>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .head { padding: 80px 0 60px; border-bottom: 1px solid var(--line); }
  .head .eyebrow { margin-bottom: 24px; }
  h1.display { font-size: clamp(56px, 7vw, 112px); margin-bottom: 32px; }
  .lead { font-size: 16px; line-height: 1.7; color: var(--ink-soft); max-width: 640px; }

  .cells-section { padding: 64px 0; border-bottom: 1px solid var(--line); }
  .cells { display: grid; grid-template-columns: repeat(2, 1fr); gap: 0; border-top: 1px solid var(--line); border-left: 1px solid var(--line); }
  .cell { padding: 36px 32px; border-right: 1px solid var(--line); border-bottom: 1px solid var(--line); display: flex; flex-direction: column; gap: 12px; transition: background .2s; }
  .cell:hover { background: var(--paper-soft); }
  .cell .k { font-family: var(--mono); font-size: 11px; letter-spacing: 0.18em; text-transform: uppercase; color: var(--muted); }
  .cell strong { font-family: var(--serif); font-weight: 500; font-size: 28px; word-break: break-all; }
  .cell .meta { font-size: 13px; color: var(--ink-soft); }

  .qr-section { padding: 80px 0; }
  .qr-row { display: grid; grid-template-columns: 1fr 1fr; gap: 40px; }
  .qr-card { display: flex; flex-direction: column; gap: 16px; padding: 32px; border: 1px solid var(--line); }
  .qr-card .k { font-family: var(--mono); font-size: 11px; letter-spacing: 0.18em; text-transform: uppercase; color: var(--muted); }
  .qr-card .meta { font-family: var(--mono); font-size: 12px; color: var(--ink-soft); }
  .qr { aspect-ratio: 1; background: white; border: 1px solid var(--line); display: grid; place-items: center; padding: 16px; }
  .qr img { width: 100%; height: 100%; object-fit: contain; }
  .qr.id-card { background: var(--paper-soft); font-family: var(--mono); text-align: center; }
  .qr.id-card strong { font-size: clamp(22px, 5vw, 44px); letter-spacing: 0.04em; word-break: break-word; }
  .qr.id-card span { color: var(--muted); font-size: 11px; letter-spacing: 0.18em; text-transform: uppercase; }

  @media (max-width: 760px) {
    .cells, .qr-row { grid-template-columns: 1fr; }
  }
</style>
