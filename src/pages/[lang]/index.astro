---
import { getCollection } from "astro:content";
import { eventSlug } from "../../data/events";
import BaseLayout from "../../layouts/BaseLayout.astro";
import { copy, languages, siteHero, siteFeatured, siteAbout, site, type Lang } from "../../data/site";

export function getStaticPaths() {
  return languages.map((lang) => ({ params: { lang } }));
}

const lang = Astro.params.lang as Lang;
const t = copy[lang];
const hero = siteHero[lang];
const featured = siteFeatured[lang];
const about = siteAbout[lang];
const events = await getCollection("events");
const proof = events.find((e) => eventSlug(e) === "proof-2026-04-26") ?? events[0];
const proofSlug = eventSlug(proof);
const proofTitle = lang === "zh" ? proof.data.titleZh : proof.data.titleEn;
const title = `${site.brand[lang].primary} — ${t.homeTitle}`;
---

<BaseLayout lang={lang} title={title} description={t.homeIntro}>
  

  <!-- UPCOMING -->
  <section class="upcoming">
    <div class="wrap">
      <div class="head">
        <span class="eyebrow">{lang === "en" ? "Upcoming Event" : "活动预告"}</span>
        <h2 class="display">{lang === "en" ? "Staged Reading Series" : "剧本朗读"}</h2>
      </div>

      <div class="grid">
        <div class="upcoming-image">
          <img src={site.upcoming} alt="Staged Reading Series" />
        </div>

        <div class="upcoming-text">
          <h2 class="display">
            <em>
              {lang === "en" ? "The Weight of Small Things" : "小事之重"}
            </em>
          </h2>

          <p>
            {lang === "en" ? (
              <>
                Some plays were written long ago, but they have never truly left the stage. 
                Across different times and cultures, these works continue to speak to questions 
                that feel familiar today: relationships, identity, freedom, social expectations, 
                and the choices people make under pressure.<br><br>

                The first reading, <strong>The Weight of Small Things</strong>,
                brings together Susan Glaspell's <em>Suppressed Desires</em> and <em>Trifles</em>
                — two early modern one-act plays in conversation.
                One uses sharp satire to expose the absurdity of over-analysis;
                the other builds quiet tension around what is overlooked, unheard, and left unsaid.<br><br>

                Presented in Mandarin with English subtitles, 
                this staged reading invites audiences across languages to rediscover 
                these classic short plays in a contemporary context.
              </>
            ) : (
              <>
                有些剧本写在很久以前，却从未真正离开舞台。跨越不同的时代与文化，
                这些作品依然回应着今天我们熟悉的问题：关系、身份、自由、社会期待，以及人在压力之下作出的选择。<br><br>

                首场朗读《小事之重》将呈现苏珊·格拉斯佩尔的两部独幕剧：《压抑的欲望》与《琐事》。
                这两部早期现代短剧彼此呼应：一部以犀利的讽刺揭示过度分析的荒诞，
                另一部则在安静的张力中展开那些被忽略、未被听见、也未曾说出口的事。<br><br>

                本次剧本朗读以普通话呈现，并配有英文字幕，邀请不同语言背景的观众在当代语境中重新发现这些经典短剧。<br><br>
                
                欢迎加入这场关于重新发现、反思与对话的读剧体验！
              </>
            )}
          </p>

          <p>
            <strong>
              {lang === "en"
                ? "Sat, Jul 4 · Sat, Jul 11"
                : "7月4日 和 7月11日 (双周六)"}
            </strong>
            <br />
            {lang === "en" ? "Two plays each day" : "每日两场"}
          </p>

          <a
            class="btn"
            href={site.soding_link}
            target="_blank"
            rel="noopener noreferrer"
          >
            {lang === "en" ? "Reserve Tickets" : "预约购票"} <span class="arr">→</span>
          </a>
        </div>
      </div>
    </div>
  </section>


  <!-- FEATURED -->
  <section class="featured">
    <div class="wrap">
      <div class="head">
        <span class="eyebrow">{featured.eyebrow}</span>
      </div>

      <div class="poster-carousel">
        {events.map((event) => (
          <a
            class="archive-poster"
            href={`/${lang}/events/${eventSlug(event)}`}
          >
            <img
              src={event.data.posterImage}
              alt={lang === "en"
                ? event.data.titleEn
                : event.data.titleZh}
            />
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- ABOUT PREVIEW -->
  <section class="about">
    <div class="wrap">
      <span class="eyebrow">{lang === "en" ? "About Us" : "关于我们"}</span>
      <p class="pull">
        {about.pull.lead}<br/>
        {about.pull.body}<em class="accent-word">{about.pull.accent}</em>{about.pull.tail}
      </p>

      <p class="lead">{hero.lead}</p>
      
      <div class="pillars">
        {about.pillars.map((p) => (
          <article>
            <span class="n">{p.n}</span>
            <h3>{p.h}</h3>
            <p>{p.p}</p>
          </article>
        ))}
      </div>
      <a class="btn secondary" href={`/${lang}/about`}>{t.aboutCta} <span class="arr">→</span></a>
    </div>
  </section>
</BaseLayout>

<style>
  .upcoming { padding: 40px 0; border-bottom: 1px solid var(--line); }
  .upcoming .head { display: flex; flex-direction: column; gap: 24px; margin-bottom: 64px; }
  .upcoming h2 em { font-family: "Inter", sans-serif; font-size: clamp(34px, 5vw, 45px); font-style: normal; line-height: 1.15; }
  .upcoming-image { aspect-ratio: 3 / 4; max-height: 600px; margin-left: 0px; overflow: hidden; background: var(--paper-soft); }
  .upcoming-image img { width: 100%; height: 100%; object-fit: cover; display: block; }
  .upcoming-text { display: flex; flex-direction: column; gap: 32px; max-width: 600px; margin-top: -20px; }
  .upcoming-text p { font-size: 16px; line-height: 1.8; color: var(--ink-soft); }


  .featured { padding: 60px 0; border-bottom: 1px solid var(--line); }
  .featured .head { display: flex; flex-direction: column; gap: 24px; margin-bottom: 64px; }
  .poster-carousel {
    display: flex;
    gap: 16px;

    overflow-x: auto;
    scroll-snap-type: x proximity;

    padding-bottom: 12px;
  }

  .archive-poster {
    flex: 0 0 260px;

    aspect-ratio: 3 / 4;
    scroll-snap-align: start;
  }

  .poster-carousel::-webkit-scrollbar {
    display: none;
  }

  .archive-poster img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }
  
  .grid { 
    display: grid; 
    grid-template-columns: 1fr 1.25fr; 
    gap: 64px; 
    max-width: 1100px; 
    margin: 40px auto 0; 
    transform: none;
  }
  
  .tape { position: absolute; top: 24px; left: -40px; transform: rotate(-8deg); background: var(--accent); color: var(--ink); font-family: var(--mono); font-size: 11px; letter-spacing: 0.18em; padding: 8px 56px; text-transform: uppercase; }
  .info .row { display: grid; grid-template-columns: 110px 1fr; gap: 32px; padding: 22px 0; border-bottom: 1px solid var(--line); align-items: start; }
  .info .row:first-of-type { border-top: 1px solid var(--line); }
  .info .row .k { font-family: var(--mono); font-size: 11px; letter-spacing: 0.18em; text-transform: uppercase; color: var(--muted); padding-top: 4px; }
  .info .row strong { font-family: var(--serif); font-weight: 500; font-size: 22px; display: block; }
  .info .row .sub { display: block; font-size: 13px; color: var(--muted); margin-top: 4px; }
  .cta-row { display: flex; gap: 12px; flex-wrap: wrap; margin-top: 32px; }


  .about { padding: 40px 0; }
  .about .eyebrow { margin-bottom: 32px; }
  .pull { font-family: var(--serif); font-size: clamp(32px, 3.6vw, 56px); line-height: 1.15; letter-spacing: -0.01em; max-width: 1100px; margin-bottom: 32px; font-style: italic; }
  .pillars { display: grid; grid-template-columns: repeat(3, 1fr); gap: 40px; margin: 60px 0 56px; padding-top: 40px; border-top: 1px solid var(--line); }
  .pillars article { display: flex; flex-direction: column; gap: 12px; }
  .pillars .n { font-family: var(--serif); font-size: 28px; font-style: italic; color: var(--accent-deep); }
  .pillars h3 { font-family: var(--serif); font-weight: 500; font-size: 28px; }
  .pillars p { font-size: 14px; line-height: 1.6; color: var(--ink-soft); }

  @media (max-width: 900px) {
    .meta { grid-template-columns: repeat(2, 1fr); gap: 24px; }
    h1.display .l { padding-left: 0 !important; }
    .lead-row { grid-template-columns: 1fr; gap: 24px; }
    .grid { grid-template-columns: 1fr; gap: 40px; transform: none;}
    .pillars { grid-template-columns: 1fr; }
    .upcoming-text { margin-top: 0; }

    .poster-carousel {
      scrollbar-width: thin;              /* Firefox */
      scrollbar-color: var(--line) transparent;
    }

    .poster-carousel::-webkit-scrollbar {
      display: block;
      height: 4px;
    }

    .poster-carousel::-webkit-scrollbar-thumb {
      background: var(--line);
      border-radius: 999px;
    }

    .poster-carousel::-webkit-scrollbar-track {
      background: transparent;
    }
  }

</style>
