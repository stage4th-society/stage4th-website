---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { copy, languages, siteHero, siteAbout, site, type Lang } from "../../data/site";

export function getStaticPaths() {
  return languages.map((lang) => ({ params: { lang } }));
}

const lang = Astro.params.lang as Lang;
const t = copy[lang];
const about = siteAbout[lang];
const paragraphs = t.aboutBody.split("\n\n");
const hero = siteHero[lang];
---
<BaseLayout lang={lang} title={`${t.aboutTitle} | ${site.brand[lang].primary}`} description={paragraphs[0]}>

  <section class="about">
    <div class="wrap">
      <h1 class="display">{t.aboutTitle}</h1>
      <p class="pull">
        {about.pull.lead}<br/>
        {about.pull.body}<em class="accent-word">{about.pull.accent}</em>{about.pull.tail}
      </p>
      <div class="body-grid">
        <div class="copy">
          {paragraphs.map((p) => <p>{p}</p>)}
        </div>
        <div class="upcoming-image">
           <img src={site.upcoming} alt="Staged Reading Series" />
           <img src={site.past} alt="past event" />
        </div>
      </div>
      <div class="pillars">
        {about.pillars.map((p) => (
          <article>
            <span class="n">{p.n}</span>
            <h3>{p.h}</h3>
            <p>{p.p}</p>
          </article>
        ))}
      </div>
      <div class="fourth-wall">
        <div>
          <span class="eyebrow">Fourth Wall</span>
          <h2 class="display">{t.fourthWallTitle}</h2>
        </div>
        <p>{t.fourthWallBody}</p>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .about { padding: 0px 0 40px; }
  .about .eyebrow { margin-bottom: 40px; }
  h1.display { font-size: clamp(56px, 7vw, 112px); margin-top: 40px; margin-bottom: 56px; }
  .pull { font-family: var(--serif); font-size: clamp(28px, 3.2vw, 48px); line-height: 1.2; font-style: italic; max-width: 1000px; padding-bottom: 64px; border-bottom: 1px solid var(--line); }
  .body-grid { display: grid; grid-template-columns: 1.2fr 1fr; gap: 64px; padding: 80px 0; align-items: start; }
  .copy p { font-size: 16px; line-height: 1.75; color: var(--ink-soft); margin-bottom: 18px; }
  .upcoming-image { display: flex; gap: 12px; margin-left: 30px; }
  .upcoming-image img { width: calc(50% - 6px); aspect-ratio: 3 / 4; object-fit: cover; }
  
  .pillars { display: grid; grid-template-columns: repeat(3, 1fr); gap: 40px; padding: 56px 0; border-top: 1px solid var(--line); border-bottom: 1px solid var(--line); }
  .pillars article { display: flex; flex-direction: column; gap: 12px; }
  .pillars .n { font-family: var(--serif); font-size: 32px; font-style: italic; color: var(--accent-deep); }
  .pillars h3 { font-family: var(--serif); font-weight: 500; font-size: 28px; }
  .pillars p { font-size: 14px; line-height: 1.6; color: var(--ink-soft); }
  
  .fourth-wall { display: grid; grid-template-columns: 1fr 1fr; gap: 64px; padding: 60px 0; align-items: start; }
  .fourth-wall p { margin-top: 70px; font-size: 16px; line-height: 1.75; color: var(--ink-soft); }
  @media (max-width: 900px) {
    .body-grid, .pillars, .fourth-wall { grid-template-columns: 1fr; gap: 40px; }
  }
</style>
