---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { copy, languages, site, type Lang } from "../../data/site";

export function getStaticPaths() {
  return languages.map((lang) => ({ params: { lang } }));
}

const lang = Astro.params.lang as Lang;
const t = copy[lang];
---

<BaseLayout lang={lang} title={`${t.aboutTitle} | ${site.brand[lang]}`} description={t.aboutBody.split("\n\n")[0]}>
  <section class="section">
    <div class="eyebrow">{site.brand[lang]}</div>
    <h1>{t.aboutTitle}</h1>
    <div class="body-copy about-copy">
      {t.aboutBody.split("\n\n").map((paragraph) => <p>{paragraph}</p>)}
    </div>
  </section>

  <section class="section section-tight">
    <div class="split">
      <div>
        <div class="eyebrow">Fourth Wall</div>
        <h2>{t.fourthWallTitle}</h2>
      </div>
      <div class="body-copy">
        <p>{t.fourthWallBody}</p>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .about-copy {
    margin-top: 34px;
  }
</style>
