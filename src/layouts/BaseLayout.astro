---
import { alternateLang, copy, localizePath, nav, site, type Lang } from "../data/site";

interface Props {
  lang: Lang;
  title: string;
  description: string;
  image?: string;
}

const { lang, title, description, image = "/assets/events/proof/banner.jpg" } = Astro.props;
const currentPath = Astro.url.pathname;
const nextLang = alternateLang(lang);
const switchPath = localizePath(currentPath, nextLang);
const absoluteImage = new URL(image, site.url).toString();
const canonical = new URL(currentPath, site.url).toString();
---

<!doctype html>
<html lang={lang === "zh" ? "zh-Hans" : "en"}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />
    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={absoluteImage} />
    <meta property="og:url" content={canonical} />
    <meta name="twitter:card" content="summary_large_image" />
    <link rel="icon" href={site.logo} />
  </head>
  <body>
    <header class="site-header">
      <a class="brand-link" href={`/${lang}`} aria-label={site.brand[lang]}>
        <img src={site.logo} alt="" width="56" height="56" />
        <span>{site.brand[lang]}</span>
      </a>
      <nav class="site-nav" aria-label="Primary navigation">
        {nav[lang].map((item) => <a href={item.href}>{item.label}</a>)}
      </nav>
      <a class="lang-switch" href={switchPath}>{nextLang === "zh" ? "中文" : "EN"}</a>
    </header>

    <main>
      <slot />
    </main>

    <footer class="site-footer">
      <div>
        <strong>{site.brand[lang]}</strong>
        <p>{copy[lang].homeTitle}</p>
      </div>
      <div class="footer-links">
        <a href={`mailto:${site.email}`}>{site.email}</a>
        <a href={site.instagram} target="_blank" rel="noreferrer">Instagram</a>
        <a href={site.xiaohongshu} target="_blank" rel="noreferrer">Xiaohongshu</a>
        <span>WeChat: {site.wechatId}</span>
      </div>
    </footer>
    <script is:inline define:vars={{ lang }}>
      window.localStorage.setItem("stage4th-lang", lang);
    </script>
  </body>
</html>

<style is:global>
  :root {
    --paper: #f5f0e4;
    --paper-deep: #e7dcc7;
    --ink: #111816;
    --muted: #5c625d;
    --line: rgba(17, 24, 22, 0.16);
    --accent: #e2ae21;
    --accent-dark: #936d08;
    --red: #9c2f27;
    --max: 1120px;
  }

  * {
    box-sizing: border-box;
  }

  html {
    background: var(--paper);
    color: var(--ink);
    font-family:
      Inter, ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI",
      "Noto Sans SC", "PingFang SC", "Microsoft YaHei", sans-serif;
    line-height: 1.55;
  }

  body {
    margin: 0;
    min-width: 320px;
  }

  a {
    color: inherit;
    text-decoration: none;
  }

  img {
    display: block;
    max-width: 100%;
  }

  p {
    color: var(--muted);
    margin: 0;
  }

  .site-header {
    align-items: center;
    background: rgba(245, 240, 228, 0.92);
    border-bottom: 1px solid var(--line);
    display: grid;
    gap: 18px;
    grid-template-columns: 1fr auto auto;
    left: 0;
    padding: 14px clamp(18px, 4vw, 44px);
    position: sticky;
    right: 0;
    top: 0;
    z-index: 20;
    backdrop-filter: blur(16px);
  }

  .brand-link {
    align-items: center;
    display: inline-flex;
    gap: 12px;
    min-width: 0;
  }

  .brand-link img {
    height: 48px;
    width: 48px;
  }

  .brand-link span {
    font-size: 15px;
    font-weight: 760;
    line-height: 1.15;
  }

  .site-nav {
    display: flex;
    gap: clamp(12px, 2.5vw, 28px);
    font-size: 14px;
    font-weight: 680;
  }

  .site-nav a,
  .lang-switch {
    border-bottom: 2px solid transparent;
    padding: 8px 0;
  }

  .site-nav a:hover,
  .lang-switch:hover {
    border-bottom-color: var(--accent);
  }

  .lang-switch {
    font-size: 13px;
    font-weight: 800;
  }

  main {
    min-height: 70vh;
  }

  .section {
    margin: 0 auto;
    max-width: var(--max);
    padding: clamp(56px, 8vw, 108px) clamp(18px, 4vw, 44px);
  }

  .section-tight {
    padding-bottom: clamp(34px, 5vw, 72px);
    padding-top: clamp(34px, 5vw, 72px);
  }

  .eyebrow {
    color: var(--accent-dark);
    font-size: 13px;
    font-weight: 850;
    letter-spacing: 0.08em;
    margin-bottom: 16px;
    text-transform: uppercase;
  }

  h1,
  h2,
  h3 {
    line-height: 1.04;
    margin: 0;
  }

  h1 {
    font-size: clamp(44px, 8vw, 92px);
    max-width: 880px;
  }

  h2 {
    font-size: clamp(32px, 5vw, 58px);
  }

  h3 {
    font-size: clamp(22px, 3vw, 34px);
  }

  .lead {
    color: var(--ink);
    font-size: clamp(19px, 2.4vw, 28px);
    margin-top: 22px;
    max-width: 820px;
  }

  .body-copy {
    display: grid;
    gap: 18px;
    max-width: 780px;
  }

  .body-copy p {
    font-size: 18px;
  }

  .button-row {
    display: flex;
    flex-wrap: wrap;
    gap: 12px;
    margin-top: 32px;
  }

  .button {
    align-items: center;
    background: var(--ink);
    border: 1px solid var(--ink);
    color: var(--paper);
    display: inline-flex;
    font-weight: 800;
    justify-content: center;
    min-height: 46px;
    padding: 12px 18px;
  }

  .button.secondary {
    background: transparent;
    color: var(--ink);
  }

  .button:hover {
    background: var(--accent);
    border-color: var(--accent);
    color: var(--ink);
  }

  .split {
    align-items: center;
    display: grid;
    gap: clamp(28px, 5vw, 72px);
    grid-template-columns: minmax(0, 1fr) minmax(280px, 0.78fr);
  }

  .feature-image {
    border: 1px solid var(--line);
    background: var(--paper-deep);
  }

  .feature-image img {
    aspect-ratio: 4 / 3;
    object-fit: cover;
    width: 100%;
  }

  .info-grid {
    display: grid;
    gap: 16px;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    margin-top: 32px;
  }

  .info-item {
    border-top: 1px solid var(--line);
    padding-top: 14px;
  }

  .info-item span {
    color: var(--muted);
    display: block;
    font-size: 13px;
    font-weight: 800;
    margin-bottom: 4px;
    text-transform: uppercase;
  }

  .site-footer {
    border-top: 1px solid var(--line);
    display: grid;
    gap: 22px;
    grid-template-columns: 1fr auto;
    margin: 0 auto;
    max-width: var(--max);
    padding: 34px clamp(18px, 4vw, 44px) 44px;
  }

  .footer-links {
    display: grid;
    gap: 8px;
    font-size: 14px;
    justify-items: end;
  }

  @media (max-width: 760px) {
    .site-header {
      grid-template-columns: 1fr auto;
    }

    .site-nav {
      grid-column: 1 / -1;
      justify-content: space-between;
      overflow-x: auto;
    }

    .brand-link span {
      font-size: 13px;
    }

    .split,
    .site-footer {
      grid-template-columns: 1fr;
    }

    .info-grid {
      grid-template-columns: 1fr;
    }

    .footer-links {
      justify-items: start;
    }
  }
</style>
