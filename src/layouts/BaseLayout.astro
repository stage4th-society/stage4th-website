---
import { nav, site, siteTicker, siteFooter, languages, localizePath, type Lang } from "../data/site";

interface Props {
  lang: Lang;
  title: string;
  description?: string;
  image?: string;
  pathname?: string;
}

const { lang, title, description = "", image, pathname: pathnameProp } = Astro.props;
const pathname = (pathnameProp ?? Astro.url.pathname.replace(/\/$/, "")) || `/${lang}`;
const ticker = siteTicker[lang];
const footer = siteFooter[lang];
const navItems = nav[lang];
const canonical = new URL(`${pathname}/`.replace(/\/+$/, "/"), site.url).toString();
const absoluteImage = new URL(image ?? "/assets/events/upcoming.jpg", site.url).toString();
---
<!doctype html>
<html lang={lang === "zh" ? "zh-Hans" : "en"}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />
    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={absoluteImage} />
    <meta property="og:url" content={canonical} />
    <meta name="twitter:card" content="summary_large_image" />

  <!-- Google Analytics -->
  <script async src="https://www.googletagmanager.com/gtag/js?id=G-QQX538HG15"></script>
  <script is:inline>
    window.dataLayer = window.dataLayer || [];
    function gtag(){dataLayer.push(arguments);}
    gtag('js', new Date());

    gtag('config', 'G-QQX538HG15');
  </script>    
  
    <link rel="icon" type="image/png" href={site.logo} />
    <link rel="icon" href="data:,">
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      rel="stylesheet"
      href="https://fonts.googleapis.com/css2?family=Fraunces:ital,opsz,wght@0,9..144,400;0,9..144,500;0,9..144,600;1,9..144,400;1,9..144,500&family=Inter:wght@400;500;600&family=JetBrains+Mono:wght@400;500&family=Noto+Serif+SC:wght@500;700&display=swap"
    />

    <style is:global>
      :root {
        --paper: #ffffff;
        --paper-soft: #fafafa;
        --paper-deep: #f3f3f3;
        --ink: #16140f;
        --ink-soft: #3a352b;
        --muted: #6b6555;
        --line: rgba(0, 0, 0, 0.08);
        --line-strong: rgba(22, 20, 15, 0.32);
        --accent: #d39c1b;
        --accent-deep: #8a6608;
        --red: #a3261d;
        --serif: "Fraunces", "Noto Serif SC", "Songti SC", "SimSun", serif;
        --sans: "Inter", -apple-system, "PingFang SC", "Microsoft YaHei", sans-serif;
        --mono: "JetBrains Mono", ui-monospace, "SFMono-Regular", monospace;
      }
      * { box-sizing: border-box; margin: 0; padding: 0; }
      html { font-size: 16px; }
      body {
        background: var(--paper);
        color: var(--ink);
        font-family: var(--sans);
        font-size: 16px;
        line-height: 1.55;
        -webkit-font-smoothing: antialiased;
      }
      a { color: inherit; text-decoration: none; }
      .wrap {
        width: min(calc(100% - 64px), 1320px);
        margin-inline: auto;
      }
      @media (max-width: 720px) {
        .wrap { width: min(calc(100% - 48px), 1320px); }
      }
      @media (max-width: 380px) {
        .wrap { width: min(calc(100% - 40px), 1320px); }
      }

      /* Ticker */
      .ticker { background: var(--ink); color: var(--paper); padding: 9px 0; }
      .ticker .row {
        display: flex; gap: 36px; align-items: center;
        font-family: var(--mono); font-size: 11px; letter-spacing: 0.06em;
        text-transform: uppercase;
        white-space: nowrap; flex-wrap: nowrap;
        -webkit-mask-image: linear-gradient(to right, transparent, black 7%, black 93%, transparent);
                mask-image: linear-gradient(to right, transparent, black 7%, black 93%, transparent);
        overflow: hidden;
      }
      .ticker span { opacity: 0.78; }
      .ticker .dot { width: 4px; height: 4px; border-radius: 50%; background: var(--accent); flex: none; }

      /* Header */
      .menu-toggle {
        display: none;
        border: none;
        background: none;
        font-size: 28px;
        cursor: pointer;
        color: var(--ink);
      }

      .mobile-menu {
        display: none;
      }

      header.site {
        position: sticky; top: 0; z-index: 50;
        background: rgba(255, 255, 255, 0.62);
        backdrop-filter: blur(12px);
        -webkit-backdrop-filter: blur(12px);
        border-bottom: 1px solid rgba(22, 20, 15, 0.08);
      }
      header.site .bar {
        display: grid; grid-template-columns: 1fr auto 1fr; align-items: center;
        padding: 18px 0;
      }
      .brand { display: flex; flex-direction: row; align-items: center; gap: 12px; line-height: 1; }
      .brand .en { font-family: var(--serif); font-weight: 600; font-size: 19px; letter-spacing: -0.01em; }
      .brand .zh { font-family: var(--mono); font-size: 10px; letter-spacing: 0.18em; text-transform: uppercase; color: var(--muted); }
      nav.primary { display: flex; gap: 28px; justify-content: center; }
      nav.primary a {
        font-size: 13px; letter-spacing: 0.02em; padding: 6px 0; position: relative;
        color: var(--ink-soft);
      }
      nav.primary a::after {
        content: ""; position: absolute; left: 0; right: 0; bottom: -2px; height: 1px;
        background: var(--ink); transform: scaleX(0); transform-origin: left; transition: transform .25s;
      }
      nav.primary a:hover, nav.primary a.active { color: var(--ink); }
      nav.primary a.active::after, nav.primary a:hover::after { transform: scaleX(1); }
      .lang-pill {
        justify-self: end;
        display: inline-flex; align-items: center; gap: 0;
        border: 1px solid var(--line-strong); border-radius: 999px;
        padding: 4px; font-family: var(--mono); font-size: 11px;
      }
      .lang-pill a { padding: 5px 11px; border-radius: 999px; color: var(--muted); letter-spacing: 0.06em; }
      .lang-pill a.active { background: var(--ink); color: var(--paper); }

      @media (max-width: 900px) {

        header.site .bar {
          grid-template-columns: auto 1fr auto;
          align-items: center;
        }

        nav.primary {
          display: none;
        }

        .menu-toggle {
          display: block;
        }

        .brand {
          justify-self: center;
          text-align: center;
        }

        .mobile-menu {
          display: flex;
          flex-direction: column;
          align-items: center;
          gap: 20px;
          
          max-height: 0;
          padding: 0;
          overflow: hidden;

          transition:
              max-height 0.5s ease,
              padding 0.5s ease;
        }

        .mobile-menu.open {
          max-height: 300px;
          padding: 24px 0;
          border-top: 1px solid var(--line);
        }

        .mobile-menu a {
          font-size: 16px;

          opacity: 0;
          transform: translateY(-6px);

          transition:
            opacity 1.8s ease,
            transform 1.8s ease;
        }
        .mobile-menu.open a {
          opacity: 1;
          transform: translateY(0);
        }
      }

      /* Buttons */
      .btn {
        display: inline-flex; align-items: center; gap: 10px;
        padding: 13px 22px; border-radius: 999px;
        background: var(--ink); color: var(--paper);
        font-size: 13px; letter-spacing: 0.04em;
        transition: transform .2s, background .2s;
      }
      .btn:hover { transform: translateY(-1px); }
      .btn .arr { transition: transform .2s; }
      .btn:hover .arr { transform: translateX(3px); }
      .btn.secondary { background: transparent; color: var(--ink); border: 1px solid var(--line-strong); }
      .btn.secondary:hover { background: var(--ink); color: var(--paper); }

      /* Eyebrow */
      .eyebrow {
        font-family: var(--mono); font-size: 11px; letter-spacing: 0.18em;
        text-transform: uppercase; color: var(--muted);
        display: inline-flex; align-items: center; gap: 12px;
      }
      .eyebrow::before { content: ""; width: 28px; height: 1px; background: currentColor; }

      /* Generic display heading */
      h1.display, h2.display {
        font-family: var(--serif);
        font-weight: 500;
        line-height: 0.96;
        letter-spacing: -0.02em;
      }
      h1.display { font-size: clamp(48px, 7.4vw, 124px); }
      h2.display { font-size: clamp(36px, 4.6vw, 72px); }
      .accent-word {
        font-style: italic; color: var(--accent-deep);
        background: linear-gradient(transparent 60%, rgba(211, 156, 27, 0.32) 60%);
        padding: 0 6px;
      }

      /* Footer */
      footer.site { background: var(--ink); color: var(--paper); margin-top: 120px; }
      footer.site .pad { padding: 96px 0 48px; }
      .foot-mark {
        font-family: var(--serif); font-style: italic; font-weight: 500;
        font-size: clamp(40px, 6.4vw, 63px); line-height: 1.04; letter-spacing: -0.015em;
        word-spacing: 0.18em; max-width: 1100px;
      }
      .foot-mark .accent {
        color: var(--accent);
        background: linear-gradient(transparent 60%, rgba(211, 156, 27, 0.28) 60%);
        padding: 0 6px;
      }
      .foot-grid {
        display: grid; grid-template-columns: 1.4fr 1fr 1fr 1fr; gap: 48px;
        margin-top: 80px; padding-top: 40px; border-top: 1px solid rgba(243, 237, 224, 0.18);
      }
      .foot-grid h4 {
        font-family: var(--mono); font-size: 11px; letter-spacing: 0.18em;
        text-transform: uppercase; color: rgba(243, 237, 224, 0.55);
        margin-bottom: 18px;
      }
      .foot-grid p { color: rgba(243, 237, 224, 0.7); font-size: 14px; max-width: 360px; }
      .foot-grid ul { list-style: none; display: flex; flex-direction: column; gap: 10px; }
      .foot-grid a { color: var(--paper); font-size: 14px; opacity: 0.78; transition: opacity .2s; }
      .foot-grid a:hover { opacity: 1; }
      .foot-grid span { color: var(--paper); font-size: 14px; opacity: 0.78; }
      .foot-meta {
        margin-top: 60px; display: flex; justify-content: space-between; gap: 24px;
        font-family: var(--mono); font-size: 11px; letter-spacing: 0.08em;
        text-transform: uppercase; color: rgba(243, 237, 224, 0.45);
      }
      @media (max-width: 900px) {
        .foot-grid { grid-template-columns: 1fr 1fr; }
        .foot-meta { flex-direction: column; }
      }
    </style>
  </head>

  <body>
    <!-- Ticker -->
    {/*
    <div class="ticker">
      <div class="wrap">
        <div class="row">
          {ticker.map((t, i) => (
            <>
              {i > 0 && <i class="dot" aria-hidden="true"></i>}
              <span>{t}</span>
            </>
          ))}
        </div>
      </div>
    </div>
     */}

    <!-- Header -->
    <header class="site">
      <div class="wrap bar">
        <button class="menu-toggle" aria-label="Menu">
          ☰
        </button>
        <a class="brand" href={`/${lang}`}>        
          {/*<img class="logo" src="/assets/logo/logo.png" alt="logo" /> */}
          <div class="brand-text">
            <span class="en">{site.brand[lang].primary}</span>
            <span class="zh">{site.brand[lang].secondary}</span>
          </div>
        </a>
        <nav class="primary">
          {navItems.map((item) => (
            <a href={item.href} class={pathname === item.href ? "active" : ""}>{item.label}</a>
          ))}
        </nav>
        <div class="lang-pill">
          {languages.map((l) => (
            <a href={localizePath(pathname, l)} class={l === lang ? "active" : ""}>
              {l === "en" ? "EN" : "中"}
            </a>
          ))}
        </div>
      </div>

        <div class="mobile-menu">
          {navItems.map((item) => (
            <a href={item.href}>
              {item.label}
            </a>
          ))}
        </div>

      <style is:global>
        .logo {
          width: 40px;
          height: 40px;
          border-radius: 50%;
          object-fit: cover;
          border: 1px solid var(--line);
        }
        .brand-text {
          display: flex;
          flex-direction: column;
          gap: 6px;
        }
      </style>
    </header>
    

    <main>
      <slot />
    </main>

    <footer class="site">
      <div class="wrap pad">
        <div class="foot-mark">
          {footer.markLead}<span class="accent">{footer.markAccent}</span>{footer.markTail}
        </div>
        <div class="foot-grid">
          <div>
            <h4>{site.brand[lang].primary}</h4>
            <p>{footer.desc}</p>
          </div>
          {footer.cols.map((c) => (
            <div>
              <h4>{c.h}</h4>
              <ul>
                {c.items.map(([label, href]) => (
                  <li>
                    {href === "#" ? (
                      <span>{label}</span>
                    ) : (
                      <a href={href} target={String(href).startsWith("http") ? "_blank" : undefined} rel="noreferrer">{label}</a>
                    )}
                  </li>
                ))}
              </ul>
            </div>
          ))}
        </div>
        <div class="foot-meta">
          {footer.meta.map((m) => <span>{m}</span>)}
        </div>
      </div>
    </footer>
    <script is:inline define:vars={{ lang }}>
      window.localStorage.setItem("stage4th-lang", lang);
      document.addEventListener("DOMContentLoaded", () => {
        const btn = document.querySelector(".menu-toggle");
        const menu = document.querySelector(".mobile-menu");

        btn?.addEventListener("click", () => {
          menu?.classList.toggle("open");
        });
      });
    </script>
  </body>
</html>
