---
import type { CollectionEntry } from "astro:content";
import { eventSlug } from "../data/events";
import { copy, type Lang } from "../data/site";

interface Props {
  event: CollectionEntry<"events">;
  lang: Lang;
}

const { event, lang } = Astro.props;
const data = event.data;
const slug = eventSlug(event);
const title = lang === "zh" ? data.titleZh : data.titleEn;
const subtitle = lang === "zh" ? data.subtitleZh : data.subtitleEn;
const description = lang === "zh" ? data.descriptionZh : data.descriptionEn;
---

<article class="event-card">
  <a href={`/${lang}/events/${slug}`} class="event-card-image">
    <img src={data.bannerImage} alt={title} loading="lazy" />
  </a>
  <div class="event-card-body">
    <span class="status">{copy[lang].past}</span>
    <h3><a href={`/${lang}/events/${slug}`}>{title}</a></h3>
    <p class="subtitle">{subtitle}</p>
    <p>{description.split("\n\n")[0]}</p>
    <a class="text-link" href={`/${lang}/events/${slug}`}>{copy[lang].viewProgram}</a>
  </div>
</article>

<style>
  .event-card {
    border-top: 1px solid var(--line);
    display: grid;
    gap: 28px;
    grid-template-columns: minmax(260px, 0.85fr) minmax(0, 1fr);
    padding-top: 28px;
  }

  .event-card-image {
    background: var(--paper-deep);
    overflow: hidden;
  }

  .event-card-image img {
    aspect-ratio: 16 / 9;
    object-fit: cover;
    transition: transform 180ms ease;
    width: 100%;
  }

  .event-card:hover img {
    transform: scale(1.03);
  }

  .event-card-body {
    display: grid;
    gap: 12px;
  }

  .status {
    color: var(--red);
    font-size: 13px;
    font-weight: 850;
    text-transform: uppercase;
  }

  .subtitle {
    color: var(--ink);
    font-weight: 760;
  }

  .text-link {
    border-bottom: 2px solid var(--accent);
    font-weight: 850;
    justify-self: start;
    margin-top: 8px;
  }

  @media (max-width: 760px) {
    .event-card {
      grid-template-columns: 1fr;
    }
  }
</style>
